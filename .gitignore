# --- Virtual Environments ---
# Copriamo tutte le varianti comuni
myvenv/
.venv/
venv/
ENV/
env/

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# --- VS Code ---
# È meglio ignorare l'intera cartella .vscode perché contiene 
# percorsi locali che darebbero errore ad altri utenti.
.vscode/

# --- OS (Sistema Operativo) ---
Thumbs.db
.DS_Store
*.swp

# --- Database ---
*.db
*.sqlite
*.sqlite3

# --- CREDENZIALI (Sicurezza Critica) ---
# Non limitarti a .env, meglio bloccare ogni variante
.env
.env.*
!.env.example
secrets.json